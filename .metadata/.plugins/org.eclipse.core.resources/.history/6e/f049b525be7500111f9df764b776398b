package com.jdbc.test;

import java.sql.Connection;
import java.sql.DriverManager;
import java.sql.SQLException;
import java.sql.Statement;

import com.jdbc.practice.DBInfo;

/*
 * Statement 객체 활용
 * 
 * JDBC용 객체
 * - Connection : DB의 연결 정보를 담고있는 객체 (연결 객체이기 때문에 사용 후 반납)
 * - Statement : 연결된 DB에 SQL문을 전달해서 실행 한 뒤, 결과를 받아내는 객체
 * - ResultSet : SQL의 쿼리문(select)실행 후 결과를 담는 객체 / insert와 delete는 int(숫자)로 반환받음
 */
public class StatementInjectionTest {

	public static void main(String[] args) {
		// searchName은 사용자로부터 입력받은 값이라고 가정
		String searchName = "최지원";
		
		String sql = "SELECT * FROM MEMBER WHERE NAME = '" + searchName +"'";
		
		// 데이터 베이스 연결 객체 생성
		try (Connection conn = DriverManager.getConnection(DBInfo.URL, DBInfo.USER, DBInfo.PASSWORD)) {
			// sql을 전달해서 값을 받아오기 위한 객체
			Statement stmt = conn.createStatement();
			stmt.excuteQuery(sql);
			
		} catch (SQLException e) {
			e.printStackTrace();
		}
		
	}

}
